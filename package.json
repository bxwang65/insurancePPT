{
  "name": "insurance-ppt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "保险计划书 → PPT 生成器 - PDF to PPT generator for Hong Kong insurance proposals",
  "bin": {
    "ppg": "./src/cli.ts",
    "fpg": "./scripts/cli_fast_pptx.ts"
  },
  "scripts": {
    "ppg": "bun run src/cli.ts",
    "extract": "bun run src/cli.ts extract",
    "generate": "bun run src/cli.ts generate",
    "eval:cases": "bun run scripts/evaluate_cases.ts",
    "render:marp": "bun run scripts/md_to_marp_ppt.ts",
    "server": "bun run src/api/server.ts",
    "dev": "bun run --watch src/api/server.ts",
    "pipeline": "bun run scripts/run_pipeline.ts",
    "test:savings-core": "bun run scripts/test_savings_formal_core.ts",
    "test:ctf-artisan-withdrawal": "bun run scripts/test_ctf_artisan_withdrawal_extraction.ts",
    "test:template-clone": "bun run scripts/test_chinese_template_clone.ts",
    "test:template-clone-broker": "bun run scripts/test_broker_template_clone.ts",
    "test:template-clone-business": "bun run scripts/test_business_template_clone.ts",
    "test:template-clone-business-no-withdraw": "bun run scripts/test_business_template_clone_no_withdraw.ts",
    "test:template-clone-ci": "bun run scripts/test_ci_template_clone.ts",
    "test:template-clone-iul": "bun run scripts/test_iul_template_clone.ts",
    "test:sunlife-iul-lumpsum": "bun run scripts/test_sunlife_iul_lumpsum.ts",
    "demo:iul-sunlife": "bun run scripts/generate_sunlife_iul_formal.ts",
    "test:template-clone-savings-ci": "bun run scripts/test_savings_ci_bundle_clone.ts",
    "test:template-clone-savings-iul": "bun run scripts/test_savings_iul_bundle_renderer.ts",
    "test:template-clone-savings-ci-iul": "bun run scripts/test_savings_ci_iul_bundle_clone.ts",
    "test:template-clone-minimal": "bun run scripts/test_minimal_template_clone.ts",
    "test:template-clone-ink": "bun run scripts/test_ink_template_clone.ts",
    "test:template-registry": "bun run scripts/test_template_clone_registry.ts",
    "test:template-clone-config": "bun run scripts/test_template_clone_config.ts",
    "test:clone-status": "bun run scripts/test_clone_status_core.ts",
    "test:template-requirements": "bun run scripts/test_template_requirements.ts",
    "test:product-bundles": "bun run scripts/test_product_bundle_core.ts",
    "test:bundle-gate": "bun run scripts/test_bundle_gate.ts",
    "test:export-readiness": "bun run scripts/test_export_readiness.ts",
    "test:company-evidence-guard": "bun run scripts/test_company_evidence_guard.ts",
    "test:company-index-quality": "bun run scripts/test_company_index_quality.ts",
    "test:company-product-match": "bun run scripts/test_company_product_match.ts",
    "test:company-selection-required": "bun run scripts/test_company_selection_required.ts",
    "test:download-auth": "bun run scripts/test_download_auth.ts",
    "test:multi-user-api-isolation": "bun run scripts/test_multi_user_api_isolation.ts",
    "test:generation-queue-cache": "bun run scripts/test_generation_queue_cache.ts",
    "demo:savings-formal": "bun run scripts/run_formal_savings_demo.ts",
    "index:company-kb": "python3.11 scripts/build_company_knowledge_index.py",
    "index:company-kb:ocr": "python3.11 scripts/build_company_knowledge_index.py --ocr-empty --ocr-max-pages 2",
    "index:templates": "python3 scripts/build_template_asset_index.py",
    "render:template-clone": "node scripts/render_template_clone.mjs",
    "audit:id-space:business": "bun run scripts/audit_clone_id_spaces.ts --template business --max-slides 6",
    "audit:id-space:minimal": "bun run scripts/audit_clone_id_spaces.ts --template minimal --max-slides 6",
    "audit:id-space:ink": "bun run scripts/audit_clone_id_spaces.ts --template ink --max-slides 6",
    "test:pdf-signatures": "bun run scripts/test_pdf_signatures.ts",
    "test:signature-extractor": "bun run scripts/test_signature_extractor.ts",
    "test:fast-path": "bun run scripts/test_fast_path_integration.ts",
    "test:cross-validate": "bun run scripts/test_cross_validator.ts",
    "test:deck-contract": "bun run scripts/test_deck_contract.ts",
    "test:signature-coverage": "bun run scripts/test_signature_coverage.ts",
    "test:fast-regression": "bun run scripts/test_fast_regression.ts",
    "test:all-fast": "bun run test:pdf-signatures && bun run test:signature-extractor && bun run test:fast-path && bun run test:cross-validate && bun run test:deck-contract && bun run test:signature-coverage && bun run test:fast-pptx",
    "test:fast-pptx": "bun run scripts/test_fast_pptx.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "hono": "^4.12.23",
    "pptxgenjs": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
